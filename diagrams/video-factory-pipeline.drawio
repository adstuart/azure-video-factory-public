<mxfile>
  <diagram name="Azure Video Factory" id="pipeline">
    <mxGraphModel dx="1950" dy="1150" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1950" pageHeight="1150" math="0" shadow="0" background="#FFFFFF">
